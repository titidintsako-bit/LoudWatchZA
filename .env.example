# ── Backend API Keys ──────────────────────────────────────
# EskomSePush via RapidAPI (https://rapidapi.com/eskomsepush/api/eskom-se-push)
RAPIDAPI_KEY=

# OpenSky Network — OAuth2 client credentials (https://opensky-network.org/apidoc/)
# Register at opensky-network.org, then create a client under your account settings
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Groq API for AI briefs (https://console.groq.com)
GROQ_API_KEY=

# AISStream — FREE real-time global AIS ship feed (https://aisstream.io)
# Register free, no credit card, instant API key
AISSTREAM_API_KEY=

# ── Database ──────────────────────────────────────────────
# Supabase project URL and keys (https://supabase.com/dashboard)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# ── Cache ─────────────────────────────────────────────────
# Upstash Redis REST API (https://console.upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Frontend (Next.js public vars) ────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Infrastructure ────────────────────────────────────────
# Backend URL (for Next.js to proxy to — set this in Vercel env)
BACKEND_URL=http://localhost:8000

# CORS origins for backend (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://loudwatch-za.vercel.app
