# ── Backend ───────────────────────────────────────────────────────────────────
# URL of the FastAPI backend (server-side only)
BACKEND_URL=http://localhost:8000

# Public aliases — use one of these if deploying on Vercel/Edge
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# WebSocket endpoint for real-time aircraft / ship feeds
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Supabase ──────────────────────────────────────────────────────────────────
# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Upstash Redis (rate limiting / caching) ───────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ── AI / Groq ─────────────────────────────────────────────────────────────────
# Used for citizen intel classification and AI brief generation
GROQ_API_KEY=gsk_...

# ── Sentry (error monitoring) ─────────────────────────────────────────────────
# DSN is public — safe to expose. Get it from sentry.io → Project Settings → DSN
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Auth token for uploading source maps during CI builds (optional but recommended)
# Create at sentry.io → Settings → Auth Tokens with project:releases scope
SENTRY_AUTH_TOKEN=sntrys_...

# ── Push Notifications (Web Push / VAPID) ─────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
